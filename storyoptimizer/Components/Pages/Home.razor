@page "/"
@using StoryOptimizer.Services
@using StoryOptimizer.Models
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@inject OllamaApiService OllamaApiService
@inject StoryProcessingService StoryProcessingService
@inject ComfyUiService ComfyUIService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Story Optimizer</PageTitle>

<div class="container-fluid">
    <h1 class="mb-4">Story Optimizer</h1>

    @if (!string.IsNullOrEmpty(_statusText))
    {
        <div class="row mb-3">
            <div class="col-md-12">
                <div class="alert @(_statusText.StartsWith("Error") ? "alert-danger" : "alert-info") alert-dismissible fade show" role="alert">
                    @_statusText
                    <button type="button" class="btn-close" @onclick="() => _statusText = string.Empty"></button>
                </div>
            </div>
        </div>
    }

    <div class="row mb-3">
        <div class="col-md-6">
            <!-- Hidden file input outside the accordion -->
            <InputFile OnChange="LoadFile" accept=".json" style="display: none;" @ref="_fileInputRef" id="fileInput" />

            <div class="accordion" id="inputAccordion">
                <!-- Before Section -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button @(isBeforeOpen ? "" : "collapsed")" type="button" @onclick="() => isBeforeOpen = !isBeforeOpen">
                            <span class="me-auto">Before</span>
                            <label for="fileInput" class="btn btn-primary btn-sm me-2" @onclick:stopPropagation="true" style="margin-bottom: 0; cursor: pointer;">Load Project</label>
                        </button>
                    </h2>
                    <div class="accordion-collapse collapse @(isBeforeOpen ? "show" : "")">
                        <div class="accordion-body">
                            <div class="mb-2">
                                <small class="text-muted">
                                    <i class="bi bi-pencil"></i> You can edit the text directly here
                                </small>
                            </div>
                            <textarea class="form-control editable-textarea" rows="20" @bind="BeforeText" @bind:event="oninput" placeholder="Paste or type your original text here. Use '##' as chapter markers..."></textarea>
                        </div>
                    </div>
                </div>

                <!-- Summary Section -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button @(isSummaryOpen ? "" : "collapsed")" type="button" @onclick="() => isSummaryOpen = !isSummaryOpen">
                            Summary (@chapterSummaries.Count chapters)
                        </button>
                    </h2>
                    <div class="accordion-collapse collapse @(isSummaryOpen ? "show" : "")">
                        <div class="accordion-body">
                            @if (chapterSummaries.Count == 0)
                            {
                                <p class="text-muted">No chapters processed yet.</p>
                            }
                            else
                            {
                                <div class="list-group">
                                    @for (int i = 0; i < chapterSummaries.Count; i++)
                                    {
                                        var index = i; // Capture for closure
                                        <div class="list-group-item">
                                            @if (editingSummaryIndex == index)
                                            {
                                                <!-- Edit Mode -->
                                                <h6 class="mb-2">Chapter @(index + 1)</h6>
                                                <textarea class="form-control mb-2" rows="3" @bind="editingSummaryText"></textarea>
                                                <div>
                                                    <button class="btn btn-success btn-sm me-2" @onclick="() => SaveSummaryEdit(index)">Save</button>
                                                    <button class="btn btn-secondary btn-sm" @onclick="CancelSummaryEdit">Cancel</button>
                                                </div>
                                            }
                                            else
                                            {
                                                <!-- View Mode -->
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <div class="flex-grow-1">
                                                        <h6 class="mb-1">Chapter @(index + 1)</h6>
                                                        <p class="mb-0">@chapterSummaries[index]</p>
                                                    </div>
                                                    <div class="btn-group-vertical ms-2">
                                                        <button class="btn btn-outline-primary btn-sm" @onclick="() => StartSummaryEdit(index)">Edit</button>
                                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveSummary(index)">Remove</button>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Characters Section -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button @(isCharactersOpen ? "" : "collapsed")" type="button" @onclick="() => isCharactersOpen = !isCharactersOpen">
                            Characters (@knownCharacters.Count)
                        </button>
                    </h2>
                    <div class="accordion-collapse collapse @(isCharactersOpen ? "show" : "")">
                        <div class="accordion-body">
                            @if (knownCharacters.Count == 0)
                            {
                                <p class="text-muted">No characters identified yet.</p>
                            }
                            else
                            {
                                <div class="list-group">
                                    @for (int i = 0; i < knownCharacters.Count; i++)
                                    {
                                        var index = i; // Capture for closure
                                        var character = knownCharacters[index];
                                        <div class="list-group-item">
                                            @if (editingCharacterIndex == index)
                                            {
                                                <!-- Edit Mode -->
                                                <div class="mb-2">
                                                    <label class="form-label mb-1"><strong>Name:</strong></label>
                                                    <input type="text" class="form-control form-control-sm" @bind="editingCharacterName" />
                                                </div>
                                                <div class="mb-2">
                                                    <label class="form-label mb-1"><strong>Role:</strong></label>
                                                    <input type="text" class="form-control form-control-sm" @bind="editingCharacterRole" />
                                                </div>
                                                <div class="mb-2">
                                                    <label class="form-label mb-1"><strong>Appearance:</strong></label>
                                                    <textarea class="form-control form-control-sm" rows="3" @bind="editingCharacterDescription"></textarea>
                                                </div>
                                                <div class="mb-2">
                                                    <label class="form-label mb-1"><strong>Introduced in Chapter:</strong></label>
                                                    <input type="number" class="form-control form-control-sm" @bind="editingCharacterIntroduced" min="1" />
                                                </div>
                                                <div class="mb-2">
                                                    <label class="form-label mb-1"><strong>Last Changed in Chapter:</strong></label>
                                                    <input type="number" class="form-control form-control-sm" @bind="editingCharacterLastChanged" min="0" placeholder="Leave 0 if never changed" />
                                                </div>
                                                <div>
                                                    <button class="btn btn-success btn-sm me-2" @onclick="() => SaveCharacterEdit(index)">Save</button>
                                                    <button class="btn btn-secondary btn-sm" @onclick="CancelCharacterEdit">Cancel</button>
                                                </div>
                                            }
                                            else
                                            {
                                                <!-- View Mode -->
                                                <div class="d-flex w-100 justify-content-between align-items-start">
                                                    <!-- Portrait -->
                                                    <div class="me-3">
                                                        @if (!string.IsNullOrEmpty(character.PortraitUrl))
                                                        {
                                                            <img src="@character.PortraitUrl" alt="@character.Name" class="character-portrait" />
                                                        }
                                                        else
                                                        {
                                                            <div class="character-portrait-placeholder">
                                                                <span>No Portrait</span>
                                                            </div>
                                                        }
                                                        <button class="btn btn-sm btn-outline-secondary mt-2 w-100"
                                                                @onclick="() => GenerateCharacterImage(index)"
                                                                disabled="@(generatingImageForIndex == index)">
                                                            @if (generatingImageForIndex == index)
                                                            {
                                                                <span>Generating...</span>
                                                            }
                                                            else
                                                            {
                                                                <span>Create Image</span>
                                                            }
                                                        </button>
                                                    </div>

                                                    <!-- Character Info -->
                                                    <div class="flex-grow-1">
                                                        <div class="d-flex w-100 justify-content-between">
                                                            <h6 class="mb-1">@character.Name</h6>
                                                            <small class="text-muted">@character.Role</small>
                                                        </div>
                                                        <div class="mb-1">
                                                            @if (character.IntroducedInChapter > 0)
                                                            {
                                                                <small class="text-muted">Introduced: Ch @character.IntroducedInChapter</small>
                                                            }
                                                            @if (character.LastChangedInChapter.HasValue)
                                                            {
                                                                <small class="text-muted ms-2">| Last changed: Ch @character.LastChangedInChapter.Value</small>
                                                            }
                                                        </div>
                                                        <p class="mb-0"><strong>Appearance:</strong> @character.Description</p>
                                                    </div>

                                                    <!-- Action Buttons -->
                                                    <div class="btn-group-vertical ms-2">
                                                        <button class="btn btn-outline-primary btn-sm" @onclick="() => StartCharacterEdit(index)">Edit</button>
                                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveCharacter(index)">Remove</button>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="d-flex align-items-center mb-2">
                <label class="form-label me-auto mb-0">
                    After
                    <small class="text-muted ms-2">
                        <i class="bi bi-pencil"></i> Click to edit directly | Right-click selection for AI edits
                    </small>
                </label>
                <button class="btn btn-success btn-sm" @onclick="SaveProject">Save Project</button>
            </div>
            <div id="afterTextEditor"
                 class="form-control after-text-editor"
                 contenteditable="true"
                 @oncontextmenu="HandleContextMenu"
                 @oncontextmenu:preventDefault="true"
                 @oninput="HandleAfterTextInput"
                 @onblur="HandleAfterTextBlur"
                 spellcheck="false"
                 data-placeholder="Processed text will appear here. You can edit it directly or right-click selected text for AI-powered edits...">@_afterText</div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-3">
            <label class="form-label">Model</label>
            <select class="form-select" @bind="selectedModel" @bind:after="OnModelChanged" disabled="@isLoadingModels">
                @if (isLoadingModels)
                {
                    <option value="">Loading models...</option>
                }
                else if (models.Count == 0)
                {
                    <option value="">No models available</option>
                }
                else
                {
                    <option value="">Select a model...</option>
                    @foreach (var model in models)
                    {
                        <option value="@model">@model</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Temperature: @temperature.ToString("0.0")</label>
            <input type="range" class="form-range" min="0.0" max="1.5" step="0.1" @bind="temperature" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Context Window: @contextWindowSize (max: @maxContextWindowSize)</label>
            <input type="range" class="form-range" min="4096" max="@maxContextWindowSize" step="4096" @bind="contextWindowSize" />
            <div class="mt-1">
                <small class="@GetVramColorClass()">
                    Estimated VRAM (approx.): @EstimatedVramGB.ToString("F1") GB
                </small>
            </div>
        </div>
        <div class="col-md-3">
            <label class="form-label">Chapter</label>
            <input type="text" class="form-control" @bind="chapter" />
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-12">
            <label class="form-label">Ruleset</label>
            <textarea class="form-control" rows="8" value="@ruleset" @onchange="@((ChangeEventArgs e) => ruleset = e.Value?.ToString() ?? "")" placeholder="AI system prompt..."></textarea>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-12">
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                <strong><i class="bi bi-info-circle"></i> Editing Tips:</strong>
                <ul class="mb-0 mt-2">
                    <li><strong>Manual Editing:</strong> Click directly in the "Before" or "After" text areas to edit text manually</li>
                    <li><strong>AI-Powered Edits:</strong> Select text in the "After" area and right-click to get AI-powered suggestions</li>
                    <li><strong>Keyboard Shortcuts:</strong> Use Ctrl+Z to undo, Ctrl+Y to redo, Ctrl+A to select all</li>
                    <li><strong>Save Your Work:</strong> Use "Save Project" button to export your work as JSON</li>
                </ul>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <button class="btn btn-info me-2" @onclick="ExtractCharacters" disabled="@isProcessing">
                @if (isProcessing && !areCharactersExtracted)
                {
                    <span>Extracting Characters...</span>
                }
                else
                {
                    <span>Extract Characters</span>
                }
            </button>
            @if (areCharactersExtracted)
            {
                <span class="text-success me-2">✓</span>
            }

            <button class="btn btn-info me-2" @onclick="GenerateSummaries" disabled="@isProcessing">
                @if (isProcessing && areCharactersExtracted && !areSummariesGenerated)
                {
                    <span>Generating Summaries...</span>
                }
                else
                {
                    <span>Generate Summaries</span>
                }
            </button>
            @if (areSummariesGenerated)
            {
                <span class="text-success me-2">✓</span>
            }

            <button class="btn btn-primary" @onclick="ApplyRuleset" disabled="@(isProcessing || !isPrepared)">
                @if (isProcessing && isPrepared)
                {
                    <span>Revising...</span>
                }
                else
                {
                    <span>Apply Ruleset (Revise Chapters)</span>
                }
            </button>

            <button class="btn btn-success ms-2" @onclick="ShowDiff" disabled="@(string.IsNullOrWhiteSpace(BeforeText) || string.IsNullOrWhiteSpace(_afterText))">
                <span>Show Diff</span>
            </button>
        </div>
    </div>
</div>

<!-- Context Menu Modal -->
@if (showContextMenu)
{
    <div class="context-menu-modal" @onclick="CloseContextMenu" @onclick:stopPropagation="false">
        <div class="context-menu-content" @onclick:stopPropagation="true">
            <h5 class="mb-3">AI Text Editor</h5>
            <div class="mb-3">
                <label class="form-label">Selected Text:</label>
                <div class="selected-text-preview">@selectedText</div>
            </div>
            <div class="mb-3">
                <label class="form-label">What would you like to do with this text?</label>
                <textarea class="form-control" rows="4" @bind="userPrompt" placeholder="E.g., 'Make it more dramatic', 'Fix grammar', 'Rewrite in a different tone'..."></textarea>
            </div>
            <div class="d-flex justify-content-end gap-2">
                <button class="btn btn-secondary" @onclick="CloseContextMenu">Cancel</button>
                <button class="btn btn-primary" @onclick="ProcessSelectedText" disabled="@(string.IsNullOrWhiteSpace(userPrompt) || isProcessingSelection)">
                    @if (isProcessingSelection)
                    {
                        <span>Processing...</span>
                    }
                    else
                    {
                        <span>Apply</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private InputFile? _fileInputRef;
    public string BeforeText = "";
    private string _afterText = "";
    private string _statusText = "";
    private string selectedModel = "";
    private double temperature = 0.8;
    private int contextWindowSize = 4096;
    private int maxContextWindowSize = 32768;
    private ModelInfo? currentModelInfo = null;
    private string chapter = "##";
    private string ruleset = @"Review and improve the chapter while maintaining the story's tone and style.
Focus on:
- Clear and engaging prose
- Consistent character voices
- Smooth pacing and flow
- Vivid descriptions
- Natural dialogue
- Fixing any grammatical errors or awkward phrasing";
    private List<string> models = new();
    private bool isLoadingModels = true;
    private bool isProcessing = false;
    private bool areCharactersExtracted = false;
    private bool areSummariesGenerated = false;
    private bool isPrepared => areCharactersExtracted && areSummariesGenerated;  // Both must be complete

    // Accordion state
    private bool isBeforeOpen = true;
    private bool isSummaryOpen = false;
    private bool isCharactersOpen = false;

    // Story tracking
    private List<CharacterInfo> knownCharacters = new();
    private List<string> chapterSummaries = new();
    private List<string>? preparedChapters = null;

    // Edit state for characters
    private int editingCharacterIndex = -1;
    private string editingCharacterName = "";
    private string editingCharacterRole = "";
    private string editingCharacterDescription = "";
    private int editingCharacterIntroduced = 1;
    private int editingCharacterLastChanged = 0;

    // Edit state for summaries
    private int editingSummaryIndex = -1;
    private string editingSummaryText = "";

    // Image generation state
    private int generatingImageForIndex = -1;

    // Context menu and text selection state
    private bool showContextMenu = false;
    private string selectedText = "";
    private string userPrompt = "";
    private bool isProcessingSelection = false;
    private string lastAfterTextValue = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadModelsFromOllama();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Sync the editor content if afterText was changed programmatically
        if (!string.IsNullOrEmpty(_afterText) && _afterText != lastAfterTextValue)
        {
            await JSRuntime.InvokeVoidAsync("setEditorContent", _afterText);
            lastAfterTextValue = _afterText;
        }
    }

    private async Task LoadModelsFromOllama()
    {
        try
        {
            isLoadingModels = true;
            models = await OllamaApiService.GetAvailableModelsAsync();
        }
        finally
        {
            isLoadingModels = false;
        }
    }

    private async Task OnModelChanged()
    {
        if (string.IsNullOrEmpty(selectedModel))
        {
            maxContextWindowSize = 32768; // Default max
            contextWindowSize = 4096; // Reset to default
            currentModelInfo = null;
            return;
        }

        try
        {
            // Get the model's info (max context, size, quantization)
            currentModelInfo = await OllamaApiService.GetModelInfoAsync(selectedModel);
            maxContextWindowSize = currentModelInfo.MaxContext;

            // Adjust current context window if it exceeds the new max
            if (contextWindowSize > maxContextWindowSize)
            {
                contextWindowSize = maxContextWindowSize;
            }
            // Or set to a reasonable default (half of max)
            else if (contextWindowSize == 4096 && maxContextWindowSize > 4096)
            {
                contextWindowSize = Math.Min(8192, maxContextWindowSize);
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error getting model info: {ex.Message}");
            maxContextWindowSize = 32768; // Fallback
            currentModelInfo = new ModelInfo { MaxContext = 32768, ModelSizeInBillions = 7.0, QuantizationBits = 4.5 };
        }
    }

    private double EstimatedVramGB
    {
        get
        {
            if (currentModelInfo == null)
                return 0.0;

            return OllamaApiService.CalculateVramUsageGB(currentModelInfo, contextWindowSize);
        }
    }

    private string GetVramColorClass()
    {
        var vram = EstimatedVramGB;

        if (vram >= 16.0)
            return "text-danger fw-bold"; // Red for >= 16GB
        else if (vram >= 12.0)
            return "text-warning fw-bold"; // Orange for >= 12GB
        else
            return "text-muted"; // Default gray
    }

    private async Task LoadFile(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file == null) return;

            using var stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024); // 100MB max (for base64 images)
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();

            var saveData = JsonSerializer.Deserialize<SaveData>(json);
            if (saveData == null)
            {
                _statusText = "Error: Invalid JSON file format.";
                return;
            }

            // Load all settings
            selectedModel = saveData.Model;
            temperature = saveData.Temperature;
            contextWindowSize = saveData.ContextWindow;
            chapter = saveData.Chapter;
            ruleset = saveData.Ruleset;
            BeforeText = saveData.Before;
            knownCharacters = saveData.Characters;
            chapterSummaries = saveData.Summaries;

            // Update model info if model was loaded
            if (!string.IsNullOrEmpty(selectedModel))
            {
                await OnModelChanged();
            }

            // Restore preparation state if we have the data
            if (!string.IsNullOrWhiteSpace(BeforeText))
            {
                // Split chapters to restore preparedChapters
                var chapters = SplitIntoChapters(BeforeText, chapter);

                if (chapters.Count > 0)
                {
                    preparedChapters = chapters;

                    // Set extraction/generation flags based on loaded data
                    areCharactersExtracted = knownCharacters.Count > 0;
                    areSummariesGenerated = chapterSummaries.Count > 0;
                }
            }

            // Open the relevant accordion sections to show loaded data
            isBeforeOpen = true;
            isCharactersOpen = knownCharacters.Count > 0;
            isSummaryOpen = chapterSummaries.Count > 0;

            // Update status message
            if (isPrepared)
            {
                _statusText = $"Project loaded successfully! Model: {selectedModel}, Characters: {knownCharacters.Count}, Summaries: {chapterSummaries.Count}. Ready to apply ruleset.";
            }
            else if (areCharactersExtracted)
            {
                _statusText = $"Project loaded successfully! Model: {selectedModel}, Characters: {knownCharacters.Count}. Generate summaries to proceed.";
            }
            else
            {
                _statusText = $"Project loaded successfully! Model: {selectedModel}. Extract characters and generate summaries to proceed.";
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LoadFile] Exception occurred: {ex.GetType().Name}");
            Console.WriteLine($"[LoadFile] Message: {ex.Message}");
            Console.WriteLine($"[LoadFile] Stack trace: {ex.StackTrace}");
            if (ex.InnerException != null)
            {
                Console.WriteLine($"[LoadFile] Inner exception: {ex.InnerException.Message}");
            }
            _statusText = $"Error loading file: {ex.Message} (see console for details)";
        }
    }

    private async Task SaveProject()
    {
        try
        {
            var saveData = new SaveData
            {
                Model = selectedModel,
                Temperature = temperature,
                ContextWindow = contextWindowSize,
                Chapter = chapter,
                Ruleset = ruleset,
                Before = BeforeText,
                Characters = knownCharacters,
                Summaries = chapterSummaries
            };

            var json = JsonSerializer.Serialize(saveData, new JsonSerializerOptions
            {
                WriteIndented = true
            });

            var fileName = $"story-project-{DateTime.Now:yyyy-MM-dd-HHmmss}.json";

            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "application/json", json);

            _statusText = $"Project saved as {fileName}";
        }
        catch (Exception ex)
        {
            _statusText = $"Error saving project: {ex.Message}";
        }
    }

    private async Task ExtractCharacters()
    {
        Console.WriteLine($"ExtractCharacters called - beforeText length: {BeforeText?.Length ?? 0}");

        if (string.IsNullOrWhiteSpace(selectedModel))
        {
            _statusText = "Error: Please select a model first.";
            return;
        }

        if (string.IsNullOrWhiteSpace(BeforeText))
        {
            _statusText = $"Error: Please provide text to process. Current length: {BeforeText?.Length ?? 0}";
            return;
        }

        if (string.IsNullOrWhiteSpace(chapter))
        {
            _statusText = "Error: Please provide a chapter marker.";
            return;
        }

        try
        {
            isProcessing = true;
            areCharactersExtracted = false;
            _afterText = "";
            _statusText = "";
            StateHasChanged();

            // Split the story into chapters
            var chapters = SplitIntoChapters(BeforeText, chapter);

            if (chapters.Count == 0)
            {
                _statusText = $"Error: No chapters found with marker '{chapter}'";
                isProcessing = false;
                return;
            }

            // Reset tracking lists for new processing run
            knownCharacters.Clear();

            _statusText = $"Extracting characters from {chapters.Count} chapters...";
            StateHasChanged();

            // Extract characters
            var characters = await StoryProcessingService.ExtractCharactersAsync(
                selectedModel,
                temperature,
                contextWindowSize,
                chapters,
                chapter,
                // Progress callback to update UI in real-time
                (status, chars) =>
                {
                    _statusText = status;
                    knownCharacters = chars;
                    StateHasChanged();
                }
            );

            // Store the prepared chapters for later use
            preparedChapters = chapters;

            // Update UI with final results
            knownCharacters = characters;
            isCharactersOpen = true;

            areCharactersExtracted = true;
            _statusText = $"Character extraction complete! Total characters found: {knownCharacters.Count}.";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ExtractCharacters] Exception occurred: {ex.GetType().Name}");
            Console.WriteLine($"[ExtractCharacters] Message: {ex.Message}");
            Console.WriteLine($"[ExtractCharacters] Stack trace: {ex.StackTrace}");
            if (ex.InnerException != null)
            {
                Console.WriteLine($"[ExtractCharacters] Inner exception: {ex.InnerException.Message}");
            }
            _statusText = $"Error: {ex.Message} (see console for details)";
            areCharactersExtracted = false;
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task GenerateSummaries()
    {
        Console.WriteLine($"GenerateSummaries called - beforeText length: {BeforeText?.Length ?? 0}");

        if (string.IsNullOrWhiteSpace(selectedModel))
        {
            _statusText = "Error: Please select a model first.";
            return;
        }

        if (string.IsNullOrWhiteSpace(BeforeText))
        {
            _statusText = $"Error: Please provide text to process. Current length: {BeforeText?.Length ?? 0}";
            return;
        }

        if (string.IsNullOrWhiteSpace(chapter))
        {
            _statusText = "Error: Please provide a chapter marker.";
            return;
        }

        try
        {
            isProcessing = true;
            areSummariesGenerated = false;
            _statusText = "";
            StateHasChanged();

            // Split the story into chapters
            var chapters = SplitIntoChapters(BeforeText, chapter);

            if (chapters.Count == 0)
            {
                _statusText = $"Error: No chapters found with marker '{chapter}'";
                isProcessing = false;
                return;
            }

            chapterSummaries.Clear();

            _statusText = $"Generating summaries for {chapters.Count} chapters...";
            StateHasChanged();

            var summaries = await StoryProcessingService.GenerateSummariesAsync(
                selectedModel,
                temperature,
                contextWindowSize,
                chapters,
                chapter,
                // Progress callback to update UI in real-time
                (status, sums) =>
                {
                    _statusText = status;
                    chapterSummaries = sums;
                    StateHasChanged();
                }
            );
            preparedChapters = chapters;
            chapterSummaries = summaries;
            isSummaryOpen = true;

            areSummariesGenerated = true;
            _statusText = $"Summary generation complete! Total summaries: {chapterSummaries.Count}. Ready to apply ruleset.";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[GenerateSummaries] Exception occurred: {ex.GetType().Name}");
            Console.WriteLine($"[GenerateSummaries] Message: {ex.Message}");
            Console.WriteLine($"[GenerateSummaries] Stack trace: {ex.StackTrace}");
            if (ex.InnerException != null)
            {
                Console.WriteLine($"[GenerateSummaries] Inner exception: {ex.InnerException.Message}");
            }
            _statusText = $"Error: {ex.Message} (see console for details)";
            areSummariesGenerated = false;
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task ApplyRuleset()
    {
        Console.WriteLine($"ApplyRuleset called - isPrepared: {isPrepared}");

        if (!isPrepared || preparedChapters == null)
        {
            _statusText = "Error: Please click 'Prepare' first to extract characters and summaries.";
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedModel))
        {
            _statusText = "Error: Please select a model first.";
            return;
        }

        if (string.IsNullOrWhiteSpace(ruleset))
        {
            _statusText = "Error: Please provide a ruleset.";
            return;
        }

        try
        {
            isProcessing = true;
            _afterText = "";
            _statusText = $"Revising {preparedChapters.Count} chapters using prepared data...";
            StateHasChanged();

            await StoryProcessingService.ReviseChaptersAsync(
                selectedModel,
                temperature,
                contextWindowSize,
                preparedChapters,
                ruleset,
                knownCharacters,
                chapterSummaries,
                (revisedChapter, currentChapter, totalChapters) =>
                {
                    _afterText += CleanService.CleanText(revisedChapter);
                    _afterText += "\n\n";
                    _statusText = $"Revising chapters... ({currentChapter}/{totalChapters} complete)";
                    StateHasChanged();
                }
            );

            _statusText = $"Revision complete! Total chapters: {preparedChapters.Count}, Characters used: {knownCharacters.Count}";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ApplyRuleset] Exception occurred: {ex.GetType().Name}");
            Console.WriteLine($"[ApplyRuleset] Message: {ex.Message}");
            Console.WriteLine($"[ApplyRuleset] Stack trace: {ex.StackTrace}");
            if (ex.InnerException != null)
            {
                Console.WriteLine($"[ApplyRuleset] Inner exception: {ex.InnerException.Message}");
            }
            _statusText = $"Error: {ex.Message} (see console for details)";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task ShowDiff()
    {
        Console.WriteLine($"[ShowDiff] Storing texts - Before: {BeforeText.Length} chars, After: {_afterText.Length} chars");

        // Store texts in localStorage so the new window can access them
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "diffBeforeText", BeforeText);
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "diffAfterText", _afterText);

        Console.WriteLine($"[ShowDiff] Texts stored in localStorage, opening window...");

        // Open the diff page in a new window using JavaScript
        await JSRuntime.InvokeVoidAsync("open", "/diff", "_blank");
    }

    // Character editing methods
    private void StartCharacterEdit(int index)
    {
        var character = knownCharacters[index];
        editingCharacterIndex = index;
        editingCharacterName = character.Name;
        editingCharacterRole = character.Role;
        editingCharacterDescription = character.Description;
        editingCharacterIntroduced = character.IntroducedInChapter;
        editingCharacterLastChanged = character.LastChangedInChapter ?? 0;
    }

    private void SaveCharacterEdit(int index)
    {
        var character = knownCharacters[index];
        character.Name = editingCharacterName;
        character.Role = editingCharacterRole;
        character.Description = editingCharacterDescription;
        character.IntroducedInChapter = editingCharacterIntroduced;
        character.LastChangedInChapter = editingCharacterLastChanged > 0 ? editingCharacterLastChanged : null;

        editingCharacterIndex = -1;
        _statusText = $"Character '{character.Name}' updated successfully.";
    }

