    private async Task GenerateCharacterImage(int index)
    {
        try
        {
            generatingImageForIndex = index;
            StateHasChanged();

            var character = knownCharacters[index];
            _statusText = $"Generating portrait for {character.Name}...";

            // Path to the workflow JSON
            var workflowPath = Path.Combine(AppContext.BaseDirectory, "Services", "image.json");

            if (!File.Exists(workflowPath))
            {
                _statusText = $"Error: Workflow file not found at {workflowPath}";
                return;
            }

            // Generate the image
            var imageUrl = await ComfyUIService.GenerateCharacterPortrait(character.Description, workflowPath);

            if (imageUrl != null)
            {
                character.PortraitUrl = imageUrl;
                _statusText = $"Portrait generated successfully for {character.Name}!";
            }
            else
            {
                _statusText = $"Error: Failed to generate portrait for {character.Name}";
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[GenerateCharacterImage] Exception occurred: {ex.GetType().Name}");
            Console.WriteLine($"[GenerateCharacterImage] Message: {ex.Message}");
            Console.WriteLine($"[GenerateCharacterImage] Stack trace: {ex.StackTrace}");
            if (ex.InnerException != null)
            {
                Console.WriteLine($"[GenerateCharacterImage] Inner exception: {ex.InnerException.Message}");
            }
            _statusText = $"Error generating portrait: {ex.Message} (see console for details)";
        }
        finally
        {
            generatingImageForIndex = -1;
            StateHasChanged();
        }
    }

    private List<string> SplitIntoChapters(string text, string chapterMarker)
    {
        var chapters = new List<string>();

        if (string.IsNullOrWhiteSpace(text) || string.IsNullOrWhiteSpace(chapterMarker))
        {
            return chapters;
        }

        // Split by the chapter marker
        var lines = text.Split('\n');
        var currentChapter = new System.Text.StringBuilder();
        bool inChapter = false;

        foreach (var line in lines)
        {
            // Check if this line starts with the chapter marker
            if (line.TrimStart().StartsWith(chapterMarker))
            {
                // Save the previous chapter if it exists
                if (inChapter && currentChapter.Length > 0)
                {
                    chapters.Add(currentChapter.ToString().Trim());
                    currentChapter.Clear();
                }

                // Mark that we're now in a chapter (skip the header line itself)
                inChapter = true;
            }
            else if (inChapter)
            {
                // Add content lines to the current chapter
                currentChapter.AppendLine(line);
            }
        }

        // Don't forget the last chapter
        if (inChapter && currentChapter.Length > 0)
        {
            chapters.Add(currentChapter.ToString().Trim());
        }

        return chapters;
    }

    // Context menu methods
    private async Task HandleContextMenu(MouseEventArgs e)
    {
        // Get selected text from JavaScript
        selectedText = await JSRuntime.InvokeAsync<string>("getSelectedText");

        if (!string.IsNullOrWhiteSpace(selectedText))
        {
            showContextMenu = true;
            userPrompt = "";
            StateHasChanged();
        }
    }

    private async Task HandleAfterTextInput()
    {
        // Sync the content from the editor back to the afterText variable
        _afterText = await JSRuntime.InvokeAsync<string>("getEditorContent");
        lastAfterTextValue = _afterText;
    }

    private async Task HandleAfterTextBlur()
    {
        // Ensure final sync when user leaves the editor
        _afterText = await JSRuntime.InvokeAsync<string>("getEditorContent");
        lastAfterTextValue = _afterText;
        StateHasChanged();
    }

    private void CloseContextMenu()
    {
        showContextMenu = false;
        selectedText = "";
        userPrompt = "";
    }

    private async Task ProcessSelectedText()
    {
        if (string.IsNullOrWhiteSpace(selectedText) || string.IsNullOrWhiteSpace(userPrompt))
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedModel))
        {
            _statusText = "Error: Please select a model first.";
            CloseContextMenu();
            return;
        }

        try
        {
            isProcessingSelection = true;
            StateHasChanged();

            // Build the system prompt
            var systemPrompt = "You are a professional writing assistant. The user has selected a portion of text and wants you to modify it according to their instructions. Return ONLY the modified text, with no explanations, no additional commentary, and no meta-text.";

            // Build the user prompt
            var fullPrompt = $"Original text:\n\"\"\"\n{selectedText}\n\"\"\"\n\nUser instruction: {userPrompt}\n\nProvide the modified text:";

            // Call the LLM
            var response = await OllamaApiService.CallOllamaAsync(
                selectedModel,
                systemPrompt,
                fullPrompt,
                temperature,
                contextWindowSize
            );

            // Replace the selected text with the response using JavaScript
            await JSRuntime.InvokeVoidAsync("replaceSelectedText", response);

            // Update the afterText variable by reading back from the editor
            _afterText = await JSRuntime.InvokeAsync<string>("getEditorContent");

            _statusText = "Text successfully modified by AI.";
            CloseContextMenu();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ProcessSelectedText] Error: {ex.Message}");
            _statusText = $"Error processing text: {ex.Message}";
            CloseContextMenu();
        }
        finally
        {
            isProcessingSelection = false;
            StateHasChanged();
        }
    }
