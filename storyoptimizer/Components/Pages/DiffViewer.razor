@page "/diff"
@using DiffPlex
@using DiffPlex.DiffBuilder
@using DiffPlex.DiffBuilder.Model
@using StoryOptimizer.Services
@rendermode InteractiveServer

<PageTitle>Text Diff</PageTitle>

<div class="diff-container">
    <div class="diff-header">
        <h3>Text Comparison</h3>
        <button class="btn btn-secondary" @onclick="Close">Close</button>
    </div>

    @if (DiffModel != null && DiffModel.Lines.Count > 0)
    {
        <div class="diff-stats">
            <span class="badge bg-success">+@addedCount added</span>
            <span class="badge bg-danger">-@removedCount removed</span>
            <span class="badge bg-warning">~@modifiedCount modified</span>
        </div>

        <div class="diff-content">
            <table class="diff-table">
                <thead>
                    <tr>
                        <th class="line-number">Line</th>
                        <th>Content</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in DiffModel.Lines)
                    {
                        var lineClass = line.Type switch
                        {
                            ChangeType.Inserted => "diff-line-added",
                            ChangeType.Deleted => "diff-line-removed",
                            ChangeType.Modified => "diff-line-modified",
                            _ => "diff-line-unchanged"
                        };

                        var prefix = line.Type switch
                        {
                            ChangeType.Inserted => "+",
                            ChangeType.Deleted => "-",
                            ChangeType.Modified => "~",
                            _ => " "
                        };

                        <tr class="@lineClass">
                            <td class="line-number">@(line.Position.HasValue ? line.Position.Value.ToString() : "")</td>
                            <td class="line-content">
                                <span class="line-prefix">@prefix</span>
                                <span class="line-text">@line.Text</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <p>No differences to display. The texts are identical.</p>
        </div>
    }
</div>

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;

    private DiffPaneModel? DiffModel { get; set; }
    private int addedCount = 0;
    private int removedCount = 0;
    private int modifiedCount = 0;
    private string beforeText = "";
    private string afterText = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Read texts from localStorage
            beforeText = CleanService.CleanText(await JSRuntime.InvokeAsync<string>("localStorage.getItem", "diffBeforeText") ?? "");
            afterText = CleanService.CleanText(await JSRuntime.InvokeAsync<string>("localStorage.getItem", "diffAfterText") ?? "");

            Console.WriteLine($"[DiffViewer] Retrieved from localStorage - Before: {beforeText.Length} chars, After: {afterText.Length} chars");

            // Clear localStorage
            await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "diffBeforeText");
            await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "diffAfterText");

            if (!string.IsNullOrEmpty(beforeText) || !string.IsNullOrEmpty(afterText))
            {
                Console.WriteLine($"[DiffViewer] Generating diff...");
                GenerateDiff();
                Console.WriteLine($"[DiffViewer] Diff generated with {DiffModel?.Lines.Count ?? 0} lines");
                StateHasChanged();
            }
            else
            {
                Console.WriteLine($"[DiffViewer] Both texts are empty!");
            }
        }
    }

    private void GenerateDiff()
    {
        var diffBuilder = new InlineDiffBuilder(new Differ());
        DiffModel = diffBuilder.BuildDiffModel(beforeText, afterText);

        // Calculate statistics
        addedCount = DiffModel.Lines.Count(l => l.Type == ChangeType.Inserted);
        removedCount = DiffModel.Lines.Count(l => l.Type == ChangeType.Deleted);
        modifiedCount = DiffModel.Lines.Count(l => l.Type == ChangeType.Modified);
    }

    private void Close()
    {
        // Close the window
        NavigationManager.NavigateTo("/");
    }
}

<style>
    .diff-container {
        padding: 20px;
        max-width: 100%;
        background-color: #fff;
    }

    .diff-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid #dee2e6;
    }

    .diff-stats {
        margin-bottom: 15px;
        padding: 10px;
        background-color: #f8f9fa;
        border-radius: 4px;
    }

    .diff-stats .badge {
        margin-right: 10px;
        font-size: 14px;
    }

    .diff-content {
        overflow-x: auto;
    }

    .diff-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Courier New', monospace;
        font-size: 14px;
    }

    .diff-table thead {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    .diff-table th {
        padding: 8px;
        text-align: left;
        font-weight: 600;
    }

    .diff-table td {
        padding: 2px 8px;
        vertical-align: top;
    }

    .line-number {
        width: 60px;
        text-align: right;
        color: #6c757d;
        background-color: #f8f9fa;
        border-right: 1px solid #dee2e6;
        user-select: none;
    }

    .line-content {
        white-space: pre-wrap;
        word-break: break-all;
    }

    .line-prefix {
        display: inline-block;
        width: 20px;
        font-weight: bold;
    }

    .line-text {
        margin-left: 5px;
    }

    .diff-line-added {
        background-color: #d4edda;
    }

    .diff-line-added .line-number {
        background-color: #c3e6cb;
    }

    .diff-line-added .line-prefix {
        color: #28a745;
    }

    .diff-line-removed {
        background-color: #f8d7da;
    }

    .diff-line-removed .line-number {
        background-color: #f5c6cb;
    }

    .diff-line-removed .line-prefix {
        color: #dc3545;
    }

    .diff-line-modified {
        background-color: #fff3cd;
    }

    .diff-line-modified .line-number {
        background-color: #ffeeba;
    }

    .diff-line-modified .line-prefix {
        color: #ffc107;
    }

    .diff-line-unchanged {
        background-color: #ffffff;
    }
</style>
